{
  "name": "papyrus-backend",
  "version": "v2.0.0-beta.2",
  "description": "Papyrus TypeScript backend",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "build": "tsc",
    "start": "node dist/api/server.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "async-mutex": "^0.5.0",
    "chokidar": "^4.0.3",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.2",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.0",
    "openai": "^4.96.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/markdown-it": "^14.1.0",
    "@types/node": "^22.15.0",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.2",
    "tsx": "^4.19.4",
    "typescript": "^5.6.0"
  }
}
