{
  "name": "papyrus",
  "version": "v2.0.0-beta.4",
  "description": "Papyrus - A modern note-taking and learning application",
  "main": "electron/main.js",
  "author": "PapyrusOR",
  "license": "MIT",
  "private": false,
  "scripts": {
    "dev": "concurrently -k -n BACKEND,FRONTEND -c cyan,magenta \"cd backend && npm run dev\" \"cd frontend && npm run dev\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:electron": "node scripts/build-electron.js dev",
    "dev:backend": "cd backend && npm run dev",
    "electron:dev": "node scripts/build-electron.js dev",
    "electron:build": "node scripts/build-electron.js build",
    "electron:build:win": "node scripts/build-electron.js build:win",
    "electron:build:mac": "node scripts/build-electron.js build:mac",
    "electron:build:linux": "node scripts/build-electron.js build:linux",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "postinstall": "cd frontend && npm install && cd ../backend && npm install",
    "build:installer": "npm run build:backend && npm run build:frontend && electron-builder --win nsis --x64 --publish=never",
    "build:all": "npm run build:backend && npm run build:frontend && electron-builder --win nsis --x64 --publish=never"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^8.2.2",
    "electron": "^41.1.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.papyrus.app",
    "productName": "Papyrus",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "backend/dist/**/*",
      "backend/package.json",
      "backend/node_modules/**/*",
      "!frontend/node_modules/**/*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "backend/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "Papyrus Team",
      "verifyUpdateCodeSignature": true
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Papyrus",
      "include": "build/installer.nsh",
      "deleteAppDataOnUninstall": false,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "sign": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Office",
      "maintainer": "Papyrus Team",
      "vendor": "Papyrus Team",
      "synopsis": "Modern note-taking and learning application",
      "description": "Papyrus is a modern note-taking and learning application with AI integration and spaced repetition."
    }
  },
  "dependencies": {
    "wait-on": "^9.0.5"
  }
}
